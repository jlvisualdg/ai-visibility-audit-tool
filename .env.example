# AI Visibility Audit Tool — environment variables
# All keys are OPTIONAL. The audit tool runs end-to-end in MOCK mode without them.
# To wire the real Perplexity engine (recommended for v1), set OPENROUTER_API_KEY
# and the tool will automatically swap from mock to real for that engine.

# OpenRouter — provides Perplexity Sonar (search-grounded, cheap, recommended)
OPENROUTER_API_KEY=

# Direct platform keys (use these to bypass OpenRouter, or to wire Claude/ChatGPT/Gemini)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=

# Optional: number of passes per (engine, topic) pair for variance-aware reporting
# Default 3. Lower it for cheap tests, raise it for client deliverables.
PASSES_PER_QUERY=3

# Optional: model to use through OpenRouter for the Perplexity engine
# Default: perplexity/sonar-pro (search-grounded)
PERPLEXITY_MODEL=perplexity/sonar-pro
